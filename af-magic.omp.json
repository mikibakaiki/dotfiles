{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "cache_duration": "none",
            "style": "full"
          },
          "template": "{{ .Path }} ",
          "foreground": "#0087d7",
          "type": "path",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none",
            "fetch_status": true
          },
          "template": "<#5fafff>(</>{{ if gt (len .HEAD) 20 }}{{ printf \"%.20s\" .HEAD }}...{{ else }}{{ .HEAD }}{{ end }}{{ if or (.Working.Changed) (.Staging.Changed) }}*{{ end }}<#5fafff>)</> ",
          "foreground": "#5fd787",
          "type": "git",
          "style": "plain",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#ffaf00{{ end }}"
          ]
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "python",
          "style": "plain",
          "foreground": "#FFD43B",
          "template": "{{ if .Venv }}({{ .Venv }}) {{ end }}"
        },
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": "{{ .UserName }}@{{ .HostName }}",
          "foreground": "#ffaf00",
          "type": "session",
          "style": "plain"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": "$ ",
          "foreground": "#8787ff",
          "type": "text",
          "style": "plain"
        }
      ]
    }
  ],
  "version": 3
}
